# Ignore Python virtual environments
.venv/
venv/
ENV/
env/

# Ignore Python cache files
__pycache__/
*.py[cod]
*$py.class
*.so

# Ignore environment variables
.env
.env.local

# Ignore IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Ignore logs
*.log
logs/
# logs/ covered for baseline captures (mcp/06-devops-baseline worker + validator sibling).
# See scripts/capture-baseline.sh and plan 5.1/5.4. Do not commit raw logs (redacted only in PR notes).

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore build artifacts
dist/
build/
*.egg-info/

# Ignore test coverage
.coverage
htmlcov/
.pytest_cache/

# Ignore temporary files
/tmp/
*.tmp
