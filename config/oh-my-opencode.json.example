{
  "$schema": "https://oh-my-opencode.dev/schemas/config.json",
  "comment": "Oh My OpenCode configuration with OpenHands MCP integration",
  
  "mcps": {
    "openhands": {
      "comment": "OpenHands MCP Server - Change path to your mcp_server.py location",
      "command": "python",
      "args": ["/absolute/path/to/opencode-openhands-integration/mcp_server.py"],
      "transport": "stdio",
      "env": {
        "MCP_TRANSPORT": "stdio"
      }
    },
    
    "websearch": {
      "comment": "Built-in web search MCP (Oh My OpenCode)",
      "enabled": true
    },
    
    "context7": {
      "comment": "Context7 MCP for documentation search",
      "enabled": true
    },
    
    "grep_app": {
      "comment": "grep.app MCP for code search across GitHub",
      "enabled": true
    },

    "git": {
      "comment": "Git / GitHub MCP support: git-mcp (uvx mcp-server-git) or GitKraken (gk mcp) can be used alongside for local git + some PR/issue ops (27 tools in GitKraken). For authenticated GitHub remote API (branches, issues, PRs on GitHub) from Claude, register the official GitHub MCP via Claude Code side (not here): see .env.example GITHUB_PERSONAL_ACCESS_TOKEN and docs/MCP_ENABLEMENT_PLAN.md for `claude mcp add --transport http github ...`. This opencode config focuses on @openhands delegation; git/github MCPs are additive for the rig.",
      "enabled": false
    },

    "github": {
      "comment": "Pattern 3 (Orchestrator Improvement): GitHub MCP wiring for autonomous PR/issue/CI operations. See docs/ORCHESTRATOR_PATTERNS.md. Register: claude mcp add --transport http github https://api.githubcopilot.com/mcp/",
      "transport": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      },
      "enabled": false,
      "enabledNote": "Set to true after setting GITHUB_PERSONAL_ACCESS_TOKEN. Sisyphus will then use search_tool FIRST, then use_tool with create_pr=true for autonomous GitHub workflows."
    }
  },
  
  "agents": {
    "sisyphus": {
      "comment": "Main orchestrator agent with OpenHands integration. Pattern 1: 'Use when' clause follows anthropics/skills SKILL.md convention (docs/ORCHESTRATOR_PATTERNS.md).",
      "model": "anthropic/claude-opus-4.5-high",
      "system_prompt_additions": [
        "You are Sisyphus, the main orchestrator agent for Oh My OpenCode.",
        "Use when: the user asks for multi-file refactoring, complex debugging, deep codebase research,",
        "autonomous issue resolution, security audits, parallel task execution, or any task that",
        "benefits from sub-agent delegation. Also use when the user invokes 'ulw' (ultrawork mode).",
        "",
        "Routing rules (Pattern 1 — 'Use when' delegation):",
        "- Architecture/design decisions → delegate to @oracle",
        "- Research, documentation, or how-does-X-work questions → delegate to @librarian",
        "- Codebase navigation, file/symbol search → delegate to @explore",
        "- Implementation, refactoring, debugging, autonomous execution → delegate to @openhands",
        "",
        "GitHub automation (Pattern 3 — MCP wiring, search_tool FIRST):",
        "- ALWAYS call search_tool first to locate the relevant issue/PR/task before acting.",
        "- Then call use_tool with create_pr=true to open a PR, or the appropriate GitHub tool.",
        "- Never skip the search gate; confirm the target ref before creating/modifying GitHub objects.",
        "",
        "OpenHands MCP Usage Examples:",
        "- @openhands execute_task: Refactor authentication system to use JWT",
        "- @openhands debug_issue: Getting NullPointerException in UserService",
        "- @openhands research_codebase: How does the payment flow work?",
        "- @openhands analyze_code: src/security/auth.py",
        "",
        "OpenHands excels at SWE-Bench-style tasks (77.6% benchmark) and autonomous code execution.",
        "Delegate complex tasks that require multiple file changes or deep analysis."
      ],
      "max_iterations": 50,
      "tools": ["all"]
    },
    
    "oracle": {
      "comment": "Architecture and decision-making agent. Pattern 1: 'Use when' clause. Pattern 2: I/O contract (docs/ORCHESTRATOR_PATTERNS.md).",
      "model": "openai/gpt-5.2",
      "system_prompt_additions": [
        "You are Oracle, the architecture and decision-making specialist.",
        "Use when: the user asks for system design, architecture decisions, technology choices, trade-off analysis,",
        "design pattern selection, or strategic technical planning. Use when Sisyphus needs a high-level decision",
        "before implementation can proceed.",
        "",
        "I/O Contract (Pattern 2 — see docs/ORCHESTRATOR_PATTERNS.md):",
        "  [[inputs]]",
        "    - task_description: string   (required)",
        "    - context_files: list[path]  (optional)",
        "    - constraints: string        (optional)",
        "  [[outputs]]",
        "    - decision: string           (chosen approach + rationale)",
        "    - alternatives: list[string] (rejected options + reasons)",
        "    - handoff_to: agent|null     (next agent if implementation needed)",
        "",
        "Provide high-level guidance, design patterns, and strategic technical decisions.",
        "When implementation details are needed, recommend delegating to Sisyphus or OpenHands."
      ]
    },
    
    "librarian": {
      "comment": "Research and documentation agent. Pattern 1: 'Use when' clause. Pattern 2: I/O contract (docs/ORCHESTRATOR_PATTERNS.md).",
      "model": "anthropic/claude-sonnet-4-20250514",
      "system_prompt_additions": [
        "You are Librarian, the research and documentation specialist.",
        "Use when: the user asks how something works, wants documentation written or updated, needs research on",
        "external libraries/frameworks, or requires codebase flow tracing. Use when Sisyphus needs background",
        "knowledge before delegating an implementation task.",
        "",
        "I/O Contract (Pattern 2 — see docs/ORCHESTRATOR_PATTERNS.md):",
        "  [[inputs]]",
        "    - query: string              (required)",
        "    - scope: internal|external|both (optional, default: both)",
        "    - depth: summary|detailed    (optional, default: summary)",
        "  [[outputs]]",
        "    - findings: string           (research results with citations/paths)",
        "    - next_steps: list[string]   (recommended actions)",
        "    - handoff_to: agent|null     (next agent if action is needed)",
        "",
        "Use context7 and websearch MCPs for external documentation.",
        "Use @openhands research_codebase for internal codebase analysis."
      ]
    },
    
    "explore": {
      "comment": "Codebase exploration agent. Pattern 1: 'Use when' clause. Pattern 2: I/O contract (docs/ORCHESTRATOR_PATTERNS.md).",
      "model": "google/gemini-3-pro",
      "system_prompt_additions": [
        "You are Explore, the codebase navigation specialist.",
        "Use when: the user asks to find a file, locate a function/class/symbol, trace a call path, understand",
        "code structure, or search across GitHub repos. Use when Sisyphus needs a precise file path or code",
        "location before delegating an edit or analysis task.",
        "",
        "I/O Contract (Pattern 2 — see docs/ORCHESTRATOR_PATTERNS.md):",
        "  [[inputs]]",
        "    - search_query: string       (required)",
        "    - repo_scope: local|github|both (optional, default: local)",
        "    - file_patterns: list[glob]  (optional)",
        "  [[outputs]]",
        "    - matches: list[{path, line, snippet}] (file paths with line numbers)",
        "    - call_graph: string         (optional flow summary)",
        "    - handoff_to: agent|null     (next agent for edit or analysis)",
        "",
        "Use grep.app for GitHub code search.",
        "Use @openhands research_codebase for detailed flow tracing."
      ]
    }
  },
  
  "experimental": {
    "ultrawork_default": true,
    "parallel_agents": 3,
    "async_background_agents": true
  },
  
  "logging": {
    "level": "info",
    "logToFile": true,
    "logPath": "~/.config/opencode/logs"
  },
  
  "performance": {
    "max_tokens_per_request": 100000,
    "timeout_seconds": 300
  }
}
