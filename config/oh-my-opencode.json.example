{
  "$schema": "https://oh-my-opencode.dev/schemas/config.json",
  "comment": "Oh My OpenCode configuration with OpenHands MCP integration — doctrine-executor Iter 5/6 (June 2026). For fan-out use persona= in agent stanzas.",

  "mcps": {
    "openhands": {
      "comment": "OpenHands MCP Server - Change path to your mcp_server.py location",
      "command": "python",
      "args": ["/absolute/path/to/opencode-openhands-integration/mcp_server.py"],
      "transport": "stdio",
      "env": {
        "MCP_TRANSPORT": "stdio"
      }
    },
    
    "websearch": {
      "comment": "Built-in web search MCP (Oh My OpenCode)",
      "enabled": true
    },
    
    "context7": {
      "comment": "Context7 MCP for documentation search",
      "enabled": true
    },
    
    "grep_app": {
      "comment": "grep.app MCP for code search across GitHub",
      "enabled": true
    },

    "git": {
      "comment": "Git / GitHub MCP support: git-mcp (uvx mcp-server-git) or GitKraken (gk mcp) can be used alongside for local git + some PR/issue ops (27 tools in GitKraken). For authenticated GitHub remote API (branches, issues, PRs on GitHub) from Claude, register the official GitHub MCP via Claude Code side (not here): see .env.example GITHUB_PERSONAL_ACCESS_TOKEN and docs/MCP_ENABLEMENT_PLAN.md for `claude mcp add --transport http github ...`. This opencode config focuses on @openhands delegation; git/github MCPs are additive for the rig.",
      "enabled": false
    }
  },
  
  "agents": {
    "sisyphus": {
      "comment": "Main orchestrator agent with OpenHands integration",
      "model": "anthropic/claude-opus-4.5-high",
      "system_prompt_additions": [
        "You are Sisyphus, the main orchestrator agent for Oh My OpenCode.",
        "When facing multi-file refactoring, complex debugging, or deep codebase research tasks,",
        "use the @openhands MCP to delegate to OpenHands agent.",
        "",
        "OpenHands MCP Usage Examples:",
        "- @openhands execute_task: Refactor authentication system to use JWT",
        "- @openhands debug_issue: Getting NullPointerException in UserService",
        "- @openhands research_codebase: How does the payment flow work?",
        "- @openhands analyze_code: src/security/auth.py",
        "",
        "OpenHands excels at SWE-Bench-style tasks (77.6% benchmark) and autonomous code execution.",
        "Delegate complex tasks that require multiple file changes or deep analysis."
      ],
      "max_iterations": 50,
      "tools": ["all"]
    },
    
    "oracle": {
      "comment": "Architecture and decision-making agent",
      "model": "openai/gpt-5.2",
      "system_prompt_additions": [
        "You are Oracle, the architecture and decision-making specialist.",
        "Provide high-level guidance, design patterns, and strategic technical decisions.",
        "When implementation details are needed, recommend delegating to Sisyphus or OpenHands."
      ]
    },
    
    "librarian": {
      "comment": "Research and documentation agent",
      "model": "anthropic/claude-sonnet-4-20250514",
      "system_prompt_additions": [
        "You are Librarian, the research and documentation specialist.",
        "Use context7 and websearch MCPs for external documentation.",
        "Use @openhands research_codebase for internal codebase analysis."
      ]
    },
    
    "explore": {
      "comment": "Codebase exploration agent",
      "model": "google/gemini-3-pro",
      "system_prompt_additions": [
        "You are Explore, the codebase navigation specialist.",
        "Use grep.app for GitHub code search.",
        "Use @openhands research_codebase for detailed flow tracing."
      ]
    },

    "doctrine-executor": {
      "comment": "Primary orchestrator-enforcer. Handles 300-ref tasks, auto-commit cadence, and PLAN COMPLETE closure. For fan-out use persona=doctrine-executor in sub-agent spawns.",
      "persona": "doctrine-executor",
      "model": "anthropic/claude-opus-4.5-high",
      "auto_commit_count": 3,
      "high_impact": true,
      "max_iterations": 80,
      "tools": ["all"],
      "system_prompt_additions": [
        "You are doctrine-executor, the primary orchestrator-enforcer for this rig.",
        "Apply 80/20 focus: address the 20% of changes that deliver 80% of value first.",
        "Init plan first as a live checklist. Update it after every meaningful unit of work.",
        "Search top repos BEFORE creating tasks (copilot search → create_task order).",
        "Auto-commit 3 times per cycle. Include verbatim user phrases in commit messages.",
        "For fan-out use persona= in every sub-agent spawn (see .agents/AGENTS.md).",
        "300-ref support: verify references from affaan-m/ECC (203 973 ★, 63 agents),",
        "  punkpeye MCP registry (88 384 ★, 1000+ tools), Composio (62 975 ★), and local.",
        "Close every session with: PLAN COMPLETE + ALL GATES GREEN + ref count ≥ 300.",
        "Anti-drift: ask yourself 'Would another agent recognise this output?' → must be Yes.",
        "Minimum 12 agents for high_impact tasks. If fewer spawned, re-spawn to 12.",
        "SKILL reference: Use when configuring agents. Path: /abs/SKILL.md"
      ]
    },

    "harness": {
      "comment": "Test execution and gate verification agent. Runs test.sh, health_check, and validates all gates before PLAN COMPLETE.",
      "persona": "harness",
      "model": "anthropic/claude-sonnet-4-20250514",
      "system_prompt_additions": [
        "You are harness, the gate-verification agent.",
        "Run test.sh and confirm output ends with '✓ All tests passed!'",
        "Verify: python -c \"from mcp_server import health_check; print(health_check())\"",
        "  Expected exact: '✓ OpenHands MCP Server is running in MOCK mode (v3.0 - June 2026)'",
        "Check claude mcp list for github and git-mcp/GitKraken entries.",
        "Report ALL GATES GREEN or list specific failures with remediation steps."
      ]
    },

    "enforcer": {
      "comment": "Anti-drift and quality enforcement agent. Ensures no silent drift in long sessions.",
      "persona": "enforcer",
      "model": "anthropic/claude-opus-4.5-high",
      "system_prompt_additions": [
        "You are enforcer, the anti-drift quality agent.",
        "After every agent turn: verify outputs are peer-recognisable.",
        "Check that PLAN COMPLETE closure is present when a session ends.",
        "Flag any deviation from doctrine-executor patterns.",
        "Enforce: auto_commit_count=3, ref_count≥300, min_agents≥12 for high_impact tasks."
      ]
    }
  },
  
  "experimental": {
    "ultrawork_default": true,
    "parallel_agents": 12,
    "async_background_agents": true,
    "persona_fan_out": true,
    "comment_parallel_agents": "Set to 12 for high_impact/300-ref tasks per doctrine-executor role"
  },
  
  "logging": {
    "level": "info",
    "logToFile": true,
    "logPath": "~/.config/opencode/logs"
  },
  
  "performance": {
    "max_tokens_per_request": 100000,
    "timeout_seconds": 300
  }
}
