# Example environment variables for OpenCode-OpenHands Integration
# Copy this file to .env and fill in your API keys

# Anthropic Claude API Key (Required for Claude models)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# OpenAI API Key (Optional, for GPT models)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Google Gemini API Key (Optional, for Gemini models)
# Get your key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here

# MCP Server Configuration
MCP_TRANSPORT=stdio
MCP_PORT=8765

# OpenHands Configuration
OPENHANDS_WORKSPACE_BASE=.
OPENHANDS_MAX_ITERATIONS=30
OPENHANDS_LOG_LEVEL=INFO

# Optional: LangSmith for tracing (debugging)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your-langsmith-key
# LANGCHAIN_PROJECT=opencode-openhands

# Optional: Custom model endpoints
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# OPENAI_BASE_URL=https://api.openai.com/v1

# GitHub MCP Personal Access Token (for `claude mcp` GitHub integration + validate_mcps.sh smoke)
# Fine-grained PAT recommended: select repo(s) for read access (Contents: Read, Issues: Read, Pull requests: Read, Metadata: Read)
# Create at: https://github.com/settings/personal-access-tokens/new
# Recommended (add-json with var expansion, supports /readonly for read-only smoke):
#   export GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...
#   claude mcp add-json github '{"type":"http","url":"https://api.githubcopilot.com/mcp","headers":{"Authorization":"Bearer '"$GITHUB_PERSONAL_ACCESS_TOKEN"'"}}'
# Or read-only tool surface: .../mcp/readonly
# Legacy: claude mcp add --transport http github https://api.githubcopilot.com/mcp/ -H "Authorization: Bearer $GITHUB_PERSONAL_ACCESS_TOKEN"
# Docker alt: claude mcp add github -e GITHUB_PERSONAL_ACCESS_TOKEN=$GITHUB_PERSONAL_ACCESS_TOKEN -- docker run -i --rm -e GITHUB_PERSONAL_ACCESS_TOKEN ghcr.io/github/github-mcp-server
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your-fine-grained-pat-here
